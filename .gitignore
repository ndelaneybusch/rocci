# ---- Rust / Cargo ----
/target/
rust/target/
**/*.rs.bk
*.pdb

# ---- maturin ----
# Compiled extension modules land in python/rocci/ during `maturin develop`
python/rocci/_core*.so
python/rocci/_core*.pyd
python/rocci/*.abi3.so
.maturin/

