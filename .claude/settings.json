{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh pr create:*)",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pr-security-gate.sh",
            "timeout": 600,
            "statusMessage": "Security-reviewing branch before opening PR..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/fix-on-save.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
